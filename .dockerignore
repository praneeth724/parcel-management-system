# Keep the build context small and let the image build cleanly.
# Composer and npm dependencies are installed fresh inside the Dockerfile.

.git
.gitattributes
.gitignore

/vendor
/node_modules
/public/build
/public/hot
/public/storage

.env
.env.*
!.env.production.example

/storage/*.key
/storage/logs/*
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/views/*

/tests
phpunit.xml
.phpunit.result.cache
/.phpunit.cache

/database/sql

/.idea
/.vscode
/.fleet
/.nova
/.zed
/.claude
_reference

README.md
docs
*.md
