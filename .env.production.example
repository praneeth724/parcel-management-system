# -----------------------------------------------------------------------------
# Production environment reference (Render + TiDB Cloud Serverless).
#
# On Render you do NOT upload this file — you enter these as environment
# variables in the dashboard (or they come from render.yaml). This file just
# documents every value and its expected form. See docs/DEPLOY.md.
# -----------------------------------------------------------------------------

APP_NAME="SwiftTrack Courier"
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=Asia/Colombo

# Generate locally with:  php artisan key:generate --show
# (starts with "base64:")
APP_KEY=

# Your live Render URL, e.g. https://swifttrack.onrender.com
APP_URL=

LOG_CHANNEL=stderr
LOG_LEVEL=error

# Keep sessions/cache/queue off the database to spare TiDB request units.
SESSION_DRIVER=cookie
CACHE_STORE=file
QUEUE_CONNECTION=sync

# --- TiDB Cloud Serverless -------------------------------------------------
# From the TiDB console: Cluster -> Connect -> "General" tab.
DB_CONNECTION=mysql
DB_HOST=gateway01.<region>.prod.aws.tidbcloud.com
DB_PORT=4000
DB_DATABASE=courier_db
DB_USERNAME=xxxxxxxxxxx.root
DB_PASSWORD=your-tidb-password

# TiDB requires a TLS connection. This path is the CA bundle inside the
# container image — leave it exactly as-is.
MYSQL_ATTR_SSL_CA=/etc/ssl/certs/ca-certificates.crt

# --- Mail ------------------------------------------------------------------
# "log" writes reset/verification links to the log instead of emailing them.
# For real email, set these to an SMTP provider (Brevo, Mailtrap, etc.).
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@swifttrack.lk"
MAIL_FROM_NAME="${APP_NAME}"

# Seed demo data on first boot only.
RUN_SEED=true
