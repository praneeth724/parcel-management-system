					}
				},
				{
					"name": "List parcel trackings",
					"request": {
						"method": "GET",
						"header": [ { "key": "Accept", "value": "application/json" } ],
						"url": {
							"raw": "{{base_url}}/parcels/{{parcel_id}}/trackings",
